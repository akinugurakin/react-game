# ============================================================
# Lumo — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını asla git'e commit etmeyin!
# ============================================================

# --- Veritabanı ---
DB_PASSWORD=lumo_dev

# --- Backend (FastAPI) ---
APP_NAME=Lumo API
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
STUDENT_SESSION_EXPIRE_MINUTES=480

# CORS — virgülle ayrılmış origin listesi
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Flutter (tablet) — bu değerler kod içinde --dart-define ile geçilir ---
# API_BASE_URL=http://10.0.2.2:8000   (Android emülatör için localhost)
# API_BASE_URL=http://localhost:8000  (iOS simülatör için)
